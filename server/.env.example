# ===== Proveedor de datos en vivo: elige UNO =====
#
# OPCIÓN A — NEXAR (Octopart): stock/precio de MUCHOS distribuidores.
#   1. Crea cuenta en https://nexar.com/
#   2. Crea una app con acceso "Supply" (scope supply.domain)
#   3. Copia este archivo a `.env` y pega las claves:
NEXAR_CLIENT_ID=
NEXAR_CLIENT_SECRET=

# OPCIÓN B — MOUSER: stock/precio del propio Mouser (más fácil, key instantánea).
#   1. Pide tu key gratis en https://www.mouser.com/api-hub/
#   2. Pégala aquí (deja Nexar vacío si usas esta):
MOUSER_API_KEY=

# Puerto del proxy (opcional, por defecto 8787)
PORT=8787
