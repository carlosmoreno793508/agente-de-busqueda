# Credenciales de la API de Nexar (Octopart)
# 1. Crea una cuenta en https://nexar.com/
# 2. Crea una aplicación con acceso a "Supply" (scope supply.domain)
# 3. Copia este archivo a `.env` y pega tus claves:

NEXAR_CLIENT_ID=tu_client_id_aqui
NEXAR_CLIENT_SECRET=tu_client_secret_aqui

# Puerto del proxy (opcional, por defecto 8787)
PORT=8787
